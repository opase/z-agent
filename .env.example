# 复制为 .env 并填入真实值。
# 加载优先级：shell 环境变量 > .env > settings.py 内默认值（空值行会被忽略）。

# ===== 大模型 API（必填）=====
DASHSCOPE_API_KEY=your-dashscope-api-key

# ===== 服务 =====
APP_HOST=127.0.0.1
APP_PORT=8080

# ===== 模型（可选，留空用默认）=====
# EMBEDDING_MODEL=text-embedding-v4
# CHAT_MODEL=glm-5.1
# RERANK_MODEL=gte-rerank-v2
# CLASSIFIER_MODEL=qwen-turbo
# VISION_MODEL=qwen3-vl

# ===== Token 预算与上下文压缩（可选）=====
# MODEL_CONTEXT_WINDOW=128000
# COMPRESSION_TRIGGER_RATIO=0.9
# REACT_RETAIN_RECENT_ROUNDS=3
# SHORT_TERM_MEMORY_RATIO=0.45

# ===== MCP / 审批（可选）=====
# MCP_CONFIG_PATH=
# APPROVAL_TIMEOUT_MINUTES=5
# APPROVAL_MAX_TOOLS_PER_SERVER=20
# MAX_MCP_SERVERS=10

# ===== SSE（可选）=====
# SSE_STRUCTURED_EVENTS=true

# ===== 文档解析器（可选）=====
# DOCUMENT_PARSER=auto              # auto | plain | mineru
# MINERU_METHOD=auto                # auto | cli | api-flash | api-precision
# MINERU_API_TOKEN=                 # 云端精准模式 token

# ===== 入库流水线（可选）=====
# INGESTION_CLEANING=true           # 启用噪声过滤
# INGESTION_DEDUP=true              # 启用语义去重
# INGESTION_DEDUP_THRESHOLD=0.92    # 语义去重相似度阈值
